# Example env (07-deployment.md). In prod use a secret manager, never plaintext .env.
# For docker-compose, point host at the service names (postgres / redis):
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/claude_ios
#   REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/claude_ios
REDIS_URL=redis://localhost:6379/0

# Postgres container bootstrap (docker-compose only). Override with real creds via secret
# manager in non-local environments — these are dev placeholders, not production secrets.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=claude_ios

# Anthropic service key (mode=credits). Never commit a real key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Output token budget per call (ADR-025). 16000 covers code/file generation without truncation;
# call stays non-streaming. Per-instance. Old default 4096 truncated landing-page generation.
ANTHROPIC_MAX_TOKENS=16000
# Upstream call hardening: request timeout (s) and SDK auto-retries on transient errors.
# Timeout raised to 120 (ADR-025) to avoid false 502 on long non-streaming generation at 16000 tokens.
ANTHROPIC_TIMEOUT_SECONDS=120
ANTHROPIC_MAX_RETRIES=2

# JWT (RS256). Configure JWKS endpoint or a static public key (Q-005-1).
JWT_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_PUBLIC_KEY=

# KMS envelope encryption for BYOK (Q-002-1). Local fallback: base64 of 32 random bytes.
KMS_KEY_ID=
KMS_LOCAL_MASTER_KEY=

# App Store Server API (Q-007-1).
APPSTORE_ENVIRONMENT=sandbox
APPSTORE_BUNDLE_ID=
APPSTORE_ROOT_CERT_DIR=
# DEV/TEST ONLY. When true and APPSTORE_ENVIRONMENT is not production, the real ES256/x5c
# StoreKit path skips Apple root-chain anchoring. The JWS signature is still checked against
# the embedded leaf certificate, but this no longer proves Apple issued the transaction.
# Keep false outside local/sandbox testing. Ignored when APPSTORE_ENVIRONMENT=production.
STOREKIT_DEV_SKIP_CERT_CHAIN_VERIFICATION=false

# StoreKit test-mode (TD-007, 09-e2e-testing.md §2). TEST/CI ONLY — MUST be false in prod.
# When true AND STOREKIT_TEST_SECRET is non-empty, the verifier additionally accepts an
# HS256 JWS signed with STOREKIT_TEST_SECRET (no Apple infra needed). The real ES256/x5c
# Apple path is unchanged and never weakened. Default false => prod fail-closed.
STOREKIT_TEST_MODE=false
# Shared secret for HS256 test transactions. Generate a random value for the e2e run; leave
# empty outside test/CI (empty => test-mode stays off even if the flag is true).
STOREKIT_TEST_SECRET=

# Billing (ADR-006).
SUBSCRIPTION_CREDITS_PER_PERIOD=1000

# Token purchase (ADR-015). Server-side mapping consumable productId -> credits (JSON object).
# Source of truth for how many credits a token-package purchase grants (never from the client
# body). Unknown productId -> 422; empty {} => every purchase 422 until configured.
TOKEN_PRODUCTS={"tokens_1500":1500,"tokens_600":600,"tokens_250":250,"tokens_100":100}

# Adapty subscription webhook (ADR-029). POST /v1/billing/adapty/webhook authorizes a static
# bearer secret (Authorization: Bearer <ADAPTY_WEBHOOK_SECRET>, constant-time compare).
# ADAPTY_WEBHOOK_SECRET: high-entropy (>= 32 bytes), per-instance, isolated from other secrets.
#   Empty => the endpoint returns 500 (mis-configured). NEVER commit a real secret.
#   The SAME value must be set in the Adapty dashboard webhook (Authorization header).
#   Provision (per instance):  openssl rand -hex 32  -> server .env  -> restart api  -> Adapty UI.
ADAPTY_WEBHOOK_SECRET=
# Adapty product -> credits map (JSON object {vendor_product_id: tokens}); empty {} => every
# subscription event falls back to ADAPTY_SUBSCRIPTION_TOKENS_GRANT below.
ADAPTY_PRODUCT_TOKENS={"weekly_xxx":1000,"yearly_yyy":1000}
# Fallback grant (integer > 0) when a vendor_product_id is absent from ADAPTY_PRODUCT_TOKENS.
# Separate from SUBSCRIPTION_CREDITS_PER_PERIOD (StoreKit path) for independent calibration.
ADAPTY_SUBSCRIPTION_TOKENS_GRANT=1000

# Admin auth (ADR-009). Isolated admin secret sent in the X-Admin-Token header. High-entropy
# (>= 32 random bytes), only via secret manager in prod — never commit a real secret. Not shared
# with JWT/KMS/ANTHROPIC/PREVIEW secrets. ADMIN_API_SECRET_PREV is the previous secret kept valid
# during rotation (grace period); clear it after rotation. Empty (unset) secrets never match.
ADMIN_API_SECRET=
ADMIN_API_SECRET_PREV=
# Per-source-IP rate limit for /v1/admin/* (req per window). Body size cap is 8 KB.
ADMIN_RATE_LIMIT_PER_MIN=10
ADMIN_SIZE_LIMIT_BODY=8192

# Website builder / preview (ADR-010, ADR-011). PREVIEW_URL_SECRET is an isolated HMAC secret for
# signed preview URLs (>= 32 random bytes), separate from JWT/KMS/ADMIN secrets — never commit it.
PREVIEW_URL_SECRET=
# Signed preview URL TTL (seconds; default 15 min).
PREVIEW_URL_TTL_SECONDS=900
# Storage limits (BYTEA in DB, TD-009): per-file 1 MB, per-project 10 MB, max 200 files.
PREVIEW_MAX_FILE_BYTES=1048576
PREVIEW_MAX_PROJECT_BYTES=10485760
PREVIEW_MAX_FILES=200
# Guard against an infinite server-side (site.*) tool loop within one message-step.
MAX_SERVER_TOOL_ROUNDS=16
# Service domain — dual role:
#   1) Traefik Host router label / ACME cert in prod (ADR-017; set in .env.prod.example).
#   2) Read by the APP to build an ABSOLUTE site.preview URL https://<SERVICE_DOMAIN>/v1/preview/...
#      (ADR-031), so the model copies the link verbatim instead of hallucinating a host.
# PUBLIC config, not a secret. Value is normalized (protocol/trailing-slash stripped to bare host).
# Local dev: leave EMPTY => site.preview returns a relative path (graceful fallback, TD-022).
SERVICE_DOMAIN=

# Trusted reverse-proxy (07-deployment.md). API runs behind a LB doing TLS termination.
# Comma-separated proxy IPs/CIDRs allowed to set X-Forwarded-For / X-Real-IP. Empty =>
# forwarding headers are ignored and the socket peer is used (safe default). Set this to
# your LB / ingress source range in prod so per-IP rate limiting sees the real client IP.
TRUSTED_PROXY_IPS=
# Number of trusted proxy hops in front of the app (e.g. CDN + LB => 2). Default 1.
TRUSTED_PROXY_HOP_COUNT=1

# DB connection pool (per process). Effective max conns ≈
# (DB_POOL_SIZE + DB_MAX_OVERFLOW) * gunicorn_workers * replicas — keep below Postgres
# max_connections. POOL_TIMEOUT in seconds (wait for a free conn), RECYCLE recycles conns
# older than N seconds to avoid stale server-side connections.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# API documentation (08-api-documentation.md, R7). Toggles /docs, /redoc, /openapi.json.
# Default true for dev/CI/staging. Set to false in prod to not expose the API schema publicly.
DOCS_ENABLED=true

# Observability.
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_SCRAPE_TOKEN=
